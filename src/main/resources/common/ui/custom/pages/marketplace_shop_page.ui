      }
    }
  }

  group #spacer {
    anchor: 100% 10
  }

  group #buttonRow {
    anchor: 100% 40
    layout-mode: left

    text-button #refreshButton {
      text: "Refresh"
      flex-weight: 1
      style {
        background-color: #2d5a87
        color: #FFFFFF
        font-size: 14
      }
    }

    group #buttonSpacer {
      anchor: 10 100%
    }

    text-button #backButton {
      text: "Back"
      flex-weight: 1
      style {
        background-color: #444444
        color: #FFFFFF
        font-size: 14
      }
    }
  }
