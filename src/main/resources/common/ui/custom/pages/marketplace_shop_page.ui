group {
  anchor: 500 480
  background-color: #1a1a2eEE
  layout-mode: vertical
  padding: 20

  label #title {
    text: "Shop"
    anchor: 100% 40
    style {
      font-size: 24
      color: #FFD700
      alignment: center
    }
  }

  label #subtitle {
    text: "Available Products"
    anchor: 100% 25
    style {
      font-size: 14
      color: #888888
      alignment: center
    }
  }

  group #productsContainer {
    anchor: 100% 300
    layout-mode: vertical
    background-color: #151525AA
    padding: 10

    group #product1Row {
      anchor: 100% 35
      layout-mode: left

      label #product1Name {
        text: ""
        flex-weight: 1
        style {
          color: #FFFFFF
          font-size: 14
        }
      }

      label #product1Price {
        text: ""
        anchor: 80 100%
        style {
          color: #00FF00
          font-size: 14
          alignment: right
        }
      }

      text-button #product1Buy {
        text: "Buy"
        anchor: 50 100%
        style {
          background-color: #2d8757
          color: #FFFFFF
          font-size: 12
        }
      }
    }

    group #product2Row {
      anchor: 100% 35
